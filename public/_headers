/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/*.js
  Content-Type: application/javascript
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Content-Type: text/css
  Cache-Control: public, max-age=31536000, immutable

# HTML 入口文件：禁止缓存，确保每次都拿最新的 SPA 入口
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# 音乐文件 MP3：支持断点续传 + 强缓存
/music/*.mp3
  Content-Type: audio/mpeg
  Accept-Ranges: bytes
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# 音乐文件 M4A（AAC 128kbps，压缩版）：支持断点续传 + 强缓存
/music/*.m4a
  Content-Type: audio/mp4
  Accept-Ranges: bytes
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# 数据文件：绝对禁止缓存（跨设备同步的核心）
/data/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0
  X-Content-Type-Options: nosniff
